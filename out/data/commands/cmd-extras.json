    {
        "id": "ext.shutdown-advanced",
        "name": "shutdown 进阶",
        "aliases": [
            "关机",
            "重启",
            "远程关机",
            "定时关机"
        ],
        "category": "cmd",
        "description": "关机、重启、注销等操作，支持远程和定时执行",
        "syntax": "shutdown [/s | /r | /l] [/t 秒] [/f] [/m \\\\计算机]",
        "examples": [
            {
                "desc": "1小时后自动关机",
                "cmd": "shutdown /s /t 3600"
            },
            {
                "desc": "取消定时关机",
                "cmd": "shutdown /a"
            },
            {
                "desc": "强制重启",
                "cmd": "shutdown /r /f /t 0"
            },
            {
                "desc": "远程关机",
                "cmd": "shutdown /s /m \\\\remote-pc /t 60"
            }
        ],
        "tags": [
            "关机",
            "重启",
            "远程"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.shutdown",
            "cmd.powercfg"
        ],
        "difficulty": "beginner"
