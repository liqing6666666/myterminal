    {
        "id": "ext.pathping",
        "name": "pathping",
        "aliases": [
            "网络诊断",
            "路由追踪",
            "延迟分析"
        ],
        "category": "cmd",
        "description": "结合 ping 和 tracert 功能，逐跳分析网络延迟和丢包率",
        "syntax": "pathping <目标>",
        "examples": [
            {
                "desc": "分析到百度的路径质量",
                "cmd": "pathping www.baidu.com"
            },
            {
                "desc": "指定最大跳数",
                "cmd": "pathping -h 15 www.baidu.com"
            }
        ],
        "tags": [
            "网络",
            "诊断",
            "延迟"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "lnx.ping",
            "cmd.tracert"
        ],
        "difficulty": "intermediate"
