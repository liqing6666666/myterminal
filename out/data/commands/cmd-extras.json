        "aliases": [
            "组策略",
            "策略更新",
            "域策略"
        ],
        "category": "cmd",
        "description": "刷新本地和 Active Directory 组策略设置，使策略变更立即生效",
        "syntax": "gpupdate [/force] [/target:{computer|user}]",
        "examples": [
            {
                "desc": "刷新所有组策略",
                "cmd": "gpupdate /force"
            },
            {
                "desc": "只刷新用户策略",
                "cmd": "gpupdate /target:user"
            }
        ],
        "tags": [
            "组策略",
            "域",
            "管理"
        ],
        "platform": [
            "windows"
        ],
        "related": [
