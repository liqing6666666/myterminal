    {
        "id": "ext.subst",
        "name": "subst",
        "aliases": [
            "虚拟驱动器",
            "路径映射",
            "盘符映射"
        ],
        "category": "cmd",
        "description": "将目录路径映射为虚拟驱动器盘符，方便快速访问常用目录",
        "syntax": "subst <盘符:> <路径>",
        "examples": [
            {
                "desc": "将目录映射为 Z 盘",
                "cmd": "subst Z: C:\\Users\\me\\projects"
            },
            {
                "desc": "删除虚拟驱动器",
                "cmd": "subst Z: /d"
            },
            {
                "desc": "查看所有虚拟驱动器",
                "cmd": "subst"
            }
        ],
        "tags": [
            "驱动器",
            "映射",
            "快捷"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.cd",
            "cmd.net"
        ],
        "difficulty": "beginner"
    },
    {
        "id": "ext.net-use",
        "name": "net use",
        "aliases": [
            "网络驱动器",
            "共享文件夹",
            "映射网络盘"
        ],
        "category": "cmd",
        "description": "连接或断开网络共享资源，可将共享文件夹映射为本地盘符",
        "syntax": "net use [盘符:] \\\\服务器\\共享 [密码] [/user:用户名]",
        "examples": [
            {
                "desc": "映射网络驱动器",
                "cmd": "net use Z: \\\\server\\share"
            },
            {
                "desc": "查看当前网络连接",
                "cmd": "net use"
            },
            {
                "desc": "断开网络驱动器",
                "cmd": "net use Z: /delete"
            }
        ],
        "tags": [
            "网络",
            "共享",
            "驱动器"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "ext.subst",
            "cmd.net"
        ],
        "difficulty": "beginner"
    },
