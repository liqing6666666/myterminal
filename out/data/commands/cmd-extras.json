[
    {
        "id": "ext.mklink",
        "name": "mklink",
        "aliases": [
            "符号链接",
            "快捷方式",
            "软链接",
            "硬链接"
        ],
        "category": "cmd",
        "description": "创建符号链接或硬链接，类似 Linux 的 ln 命令",
        "syntax": "mklink [/D | /H | /J] <链接> <目标>",
        "examples": [
            {
                "desc": "创建文件符号链接",
                "cmd": "mklink link.txt original.txt"
            },
            {
                "desc": "创建目录符号链接",
                "cmd": "mklink /D linkdir targetdir"
            },
            {
                "desc": "创建硬链接",
                "cmd": "mklink /H link.txt original.txt"
            }
        ],
        "tags": [
            "链接",
            "文件",
            "快捷方式"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.copy",
            "cmd.dir"
        ],
        "difficulty": "intermediate"
    },
    {
        "id": "ext.sc",
        "name": "sc",
        "aliases": [
            "服务管理",
            "Windows服务",
            "服务控制"
        ],
        "category": "cmd",
        "description": "与 Windows 服务控制管理器通信，查询、启动、停止、创建和删除服务",
        "syntax": "sc <服务器> <命令> [服务名]",
        "examples": [
            {
                "desc": "查询服务状态",
                "cmd": "sc query wuauserv"
            },
            {
                "desc": "启动服务",
                "cmd": "sc start wuauserv"
            },
            {
                "desc": "停止服务",
                "cmd": "sc stop wuauserv"
            },
            {
                "desc": "设置服务为自动启动",
                "cmd": "sc config myservice start= auto"
            }
        ],
        "tags": [
            "服务",
            "系统",
            "管理"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.tasklist",
            "cmd.net"
        ],
        "difficulty": "intermediate"
    },
    {
        "id": "ext.icacls",
        "name": "icacls",
        "aliases": [
            "权限管理",
            "文件权限",
            "ACL",
            "访问控制"
        ],
        "category": "cmd",
        "description": "显示和修改文件的访问控制列表（ACL），管理文件和目录权限",
        "syntax": "icacls <文件> [/grant | /deny | /remove] [用户:权限]",
        "examples": [
            {
                "desc": "查看文件权限",
                "cmd": "icacls file.txt"
            },
            {
                "desc": "授予用户完全控制权限",
                "cmd": "icacls file.txt /grant username:F"
            },
            {
                "desc": "移除用户权限",
                "cmd": "icacls file.txt /remove username"
            }
        ],
        "tags": [
            "权限",
            "安全",
            "文件"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.attrib",
            "cmd.takeown"
        ],
        "difficulty": "advanced"
    },
    {
        "id": "ext.takeown",
        "name": "takeown",
        "aliases": [
            "获取所有权",
            "文件所有权",
            "权限获取"
        ],
        "category": "cmd",
        "description": "获取文件或文件夹的所有权，常用于恢复对系统文件的访问权限",
        "syntax": "takeown [/F <文件>] [/R] [/A]",
        "examples": [
            {
                "desc": "获取文件所有权",
                "cmd": "takeown /f file.txt"
            },
            {
                "desc": "递归获取文件夹所有权",
                "cmd": "takeown /f C:\\folder /r"
            }
        ],
        "tags": [
            "权限",
            "所有权",
            "文件"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "ext.icacls",
            "cmd.attrib"
        ],
        "difficulty": "intermediate"
    },
    {
        "id": "ext.wmic",
        "name": "wmic",
        "aliases": [
            "WMI",
            "系统信息",
            "硬件信息",
            "wmic查询"
        ],
        "category": "cmd",
        "description": "Windows Management Instrumentation 命令行工具，查询系统硬件和软件信息",
        "syntax": "wmic <别名> [get/list/call]",
        "examples": [
            {
                "desc": "查看 CPU 信息",
                "cmd": "wmic cpu get name,numberofcores"
            },
            {
                "desc": "查看内存信息",
                "cmd": "wmic memorychip get capacity,speed"
            },
            {
                "desc": "查看已安装软件列表",
                "cmd": "wmic product get name,version"
            }
        ],
        "tags": [
            "系统",
            "硬件",
            "信息"
        ],
        "platform": [
            "windows"
        ],
        "related": [
            "cmd.systeminfo",
            "cmd.driverquery"
        ],
        "difficulty": "intermediate"
    },
    {
